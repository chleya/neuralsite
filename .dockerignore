# =============================================================================
# NeuralSite Docker Ignore
# Excludes files not needed in Docker builds
# =============================================================================

# ----------------------------------------------------------------------------- 
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python (development only)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
ENV/
env/
.eggs/

# -----------------------------------------------------------------------------
# Node.js (development only)
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock
.npm
.yarn-integrity

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage/
*.cover

# -----------------------------------------------------------------------------
# Documentation (keep minimal)
# -----------------------------------------------------------------------------
*.md
LICENSE
docs/
*.txt

# -----------------------------------------------------------------------------
# Configuration (secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
config.local.*
secrets/

# -----------------------------------------------------------------------------
# Development files
# -----------------------------------------------------------------------------
docker-compose.yml
docker-compose.dev.yml
docker-compose.prod.yml
Dockerfile
Dockerfile.dev
Makefile
deploy.sh
nginx.conf

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# Database files
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# Media (runtime uploads)
# -----------------------------------------------------------------------------
uploads/*
!uploads/.gitkeep

# -----------------------------------------------------------------------------
# Frontend source (only need dist)
# -----------------------------------------------------------------------------
packages/studio/src/
packages/studio/node_modules/
packages/studio/.git/
packages/studio/*.config.js
packages/studio/*.config.ts
packages/studio/tsconfig*
packages/studio/postcss.config.js
packages/studio/tailwind.config.js

# -----------------------------------------------------------------------------
# Backend source (keep only what Docker needs)
# -----------------------------------------------------------------------------
packages/core/test/
packages/core/tests/
packages/core/*.md
!packages/core/requirements.txt
