{
  "issues": [
    {
      "name": "混凝土裂缝",
      "category": "混凝土工程",
      "description": "混凝土结构表面或内部出现各种形式的裂缝",
      "causes": [
        "混凝土配合比不当（水灰比过大）",
        "混凝土收缩变形",
        "温度应力作用",
        "地基不均匀沉降",
        "施工养护不到位",
        "荷载过早施加"
      ],
      "solutions": [
        "表面裂缝：采用表面封闭法，涂刷环氧树脂或水泥基渗透结晶材料",
        "深度裂缝：采用压力灌浆法，注入环氧树脂或水泥浆",
        "贯穿裂缝：采取结构加固措施"
      ],
      "preventive_measures": [
        "严格控制混凝土配合比",
        "加强混凝土保湿养护不少于14天",
        "合理设置施工缝和伸缩缝",
        "控制拆模时间和荷载施加时间",
        "采取保温或降温措施"
      ],
      "related_standards": ["GB 50204-2015"]
    },
    {
      "name": "混凝土蜂窝",
      "category": "混凝土工程",
      "description": "混凝土表面出现蜂窝状孔洞",
      "causes": [
