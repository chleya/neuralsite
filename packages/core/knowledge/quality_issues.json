        "模板漏浆",
        "石子粒径过大卡住",
        "混凝土流动性不足"
      ],
      "solutions": [
        "轻微蜂窝：剔凿松散部分，湿润后用1:2水泥砂浆修补",
        "严重蜂窝：剔除至密实部位，支模后用细石混凝土补强"
      ],
      "preventive_measures": [
        "确保充分振捣",
        "防止混凝土离析",
        "模板拼缝严密",
