# -*- coding: utf-8 -*-
"""
表格页面模板
"""

TABLE_PAGE_TEMPLATE = '''
<template>
  <div class="{{ class_name }}">
    <!-- 搜索区域 -->
    <el-card class="search-card" v-if="showSearch">
      <el-form :model="searchForm" ref="searchFormRef" label-width="100px">
        <el-row :gutter="20">
          {%- for field in search_fields %}
          <el-col :span="6">
            <el-form-item label="{{ field.label }}" prop="{{ field.name }}">
              <el-input 
                v-model="searchForm.{{ field.name }}" 
                placeholder="请输入{{ field.label }}"
                clearable
              />
            </el-form-item>
          </el-col>
          {%- endfor %}
          <el-col :span="6">
            <el-form-item>
              <el-button type="primary" @click="handleSearch">查询</el-button>
              <el-button @click="handleReset">重置</el-button>
            </el-form-item>
          </el-col>
        </el-row>
      </el-form>
    </el-card>
    
    <!-- 操作按钮 -->
    <div class="toolbar">
      <el-button type="primary" @click="handleAdd">新增</el-button>
      <el-button :disabled="!selectedRows.length" @click="handleBatchDelete">批量删除</el-button>
      <el-button @click="showSearch = !showSearch">{{ showSearch ? '隐藏搜索' : '显示搜索' }}</el-button>
    </div>
    
    <!-- 表格 -->
    <el-table 
      :data="tableData" 
      v-loading="loading"
      @selection-change="handleSelectionChange"
      style="width: 100%"
    >
      <el-table-column type="selection" width="55" />
      {%- for field in table_fields %}
      <el-table-column 
        prop="{{ field.name }}" 
        label="{{ field.label }}"
        {%- if field.width %}
        width="{{ field.width }}"
        {%- endif %}
        {%- if field.sortable %}
        sortable
        {%- endif %}
      />
      {%- endfor %}
      <el-table-column label="操作" width="180" fixed="right">
        <template #default="scope">
          <el-button link type="primary" @click="handleEdit(scope.row)">编辑</el-button>
          <el-button link type="danger" @click="handleDelete(scope.row)">删除</el-button>
        </template>
      </el-table-column>
    </el-table>
    
    <!-- 分页 -->
    <el-pagination
      v-model:current-page="pagination.page"
      v-model:page-size="pagination.size"
      :total="pagination.total"
      :page-sizes="[10, 20, 50, 100]"
      layout="total, sizes, prev, pager, next, jumper"
      @size-change="handleSizeChange"
      @current-change="handleCurrentChange"
    />
  </div>
</template>

<script setup>
import { ref, reactive, onMounted } from 'vue'
import { ElMessage, ElMessageBox } from 'element-plus'

// 状态
const loading = ref(false)
const showSearch = ref(true)
const tableData = ref([])
const selectedRows = ref([])

// 搜索表单
const searchForm = reactive({
  {%- for field in search_fields %}
  {{ field.name }}: '',
  {%- endfor %}
})

// 分页
const pagination = reactive({
  page: 1,
  size: 10,
  total: 0
})

// 表格字段
const tableFields = {{ table_fields | tojson }}

// 搜索字段
const searchFields = {{ search_fields | tojson }}

// 加载数据
async function loadData() {
  loading.value = true
  try {
    const params = {
      ...searchForm,
      page: pagination.page,
      size: pagination.size
    }
    const res = await api.get{{ table_name | capitalize }}List(params)
    tableData.value = res.data.list
    pagination.total = res.data.total
  } catch (error) {
    ElMessage.error('加载失败')
  } finally {
    loading.value = false
  }
}

// 搜索
function handleSearch() {
  pagination.page = 1
  loadData()
}

// 重置
function handleReset() {
  Object.keys(searchForm).forEach(key => {
    searchForm[key] = ''
  })
  handleSearch()
}

// 新增
function handleAdd() {
  // TODO: 实现新增逻辑
}

// 编辑
function handleEdit(row) {
  // TODO: 实现编辑逻辑
}

// 删除
async function handleDelete(row) {
  try {
    await ElMessageBox.confirm('确认删除?', '提示', { type: 'warning' })
    await api.delete{{ table_name | capitalize }}(row.id)
    ElMessage.success('删除成功')
    loadData()
  } catch (error) {
    if (error !== 'cancel') {
      ElMessage.error('删除失败')
    }
  }
}

// 批量删除
async function handleBatchDelete() {
  // TODO: 实现批量删除
}

// 选择变化
function handleSelectionChange(rows) {
  selectedRows.value = rows
}

// 分页变化
function handleSizeChange() {
  loadData()
}

function handleCurrentChange() {
  loadData()
}

onMounted(() => {
  loadData()
})
</script>

<style scoped>
.{{ class_name }} {
  padding: 20px;
}
.search-card {
  margin-bottom: 20px;
}
.toolbar {
  margin-bottom: 20px;
}
</style>
'''
